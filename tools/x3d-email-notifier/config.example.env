# Copy this file to .env in this folder and fill in your mailbox details.
# Use an app password when your provider supports it. Do not commit .env.

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=mail@example.com
IMAP_PASS=app-password-here
IMAP_MAILBOX=INBOX

# Keep true when your local Node trust store accepts the mail certificate.
# Set false only when your provider/certificate chain cannot be verified locally.
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Poll interval for new mail checks.
POLL_INTERVAL_SECONDS=45

# First run normally marks existing mail as already seen to avoid a flood.
NOTIFY_EXISTING_ON_FIRST_RUN=false

# Default: notify only for unread messages. This prevents already-opened mail from popping up.
NOTIFIER_UNREAD_ONLY=true

# Optional filters. Leave empty to notify for all unseen/new messages.
NOTIFIER_ALLOWED_FROM=
NOTIFIER_SUBJECT_KEYWORDS=

# Visual tuning.
NOTIFIER_BRAND=X3DPrints
NOTIFIER_DURATION_MS=12000
NOTIFIER_SOUND=false
NOTIFIER_OPEN_URL=https://mail.zxcs.nl
NOTIFIER_MAX_NOTIFICATION_AGE_SECONDS=300

# Multi-monitor placement: primary, cursor, 1, 2, 3...
NOTIFIER_MONITOR=primary
NOTIFIER_EDGE=left
NOTIFIER_TOP_OFFSET=28
