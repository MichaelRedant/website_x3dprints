{
  "name": "x3dprints",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-with-distdir.mjs dev .next-dev",
    "clean": "node scripts/clean-build-artifacts.mjs",
    "build": "next build",
    "postbuild": "node scripts/postbuild-html-lang.mjs && node scripts/write-apache-htaccess.mjs",
    "start": "npm run preview",
    "preview": "npx serve -s out -l 3000",
    "lint": "eslint",
    "check:security:public-data": "node scripts/check-security-public-data.mjs",
    "check:security:crm-auth": "node scripts/check-security-crm-auth.mjs",
    "check:security": "npm run check:security:public-data && npm run check:security:crm-auth",
    "verify": "npm run lint && npm run check:security && npm run build && npm run check:seo",
    "test": "vitest run",
    "check:seo:metadata": "node scripts/check-seo-metadata.mjs",
    "check:seo:locale-diff": "node scripts/check-seo-locale-diff.mjs",
    "check:seo:locale-links": "node scripts/check-seo-locale-links.mjs",
    "check:seo:templates": "node scripts/check-seo-templates.mjs",
    "check:seo:quality": "node scripts/check-seo-quality.mjs",
    "check:seo:html-lang": "node scripts/check-seo-html-lang.mjs",
    "check:seo:schema": "node scripts/check-seo-schema.mjs",
    "check:seo:schema:locale": "node scripts/check-seo-schema-locale.mjs",
    "check:seo:og": "node scripts/check-seo-og.mjs",
    "check:seo:robots": "node scripts/check-seo-robots.mjs",
    "check:seo:sitemap": "node scripts/check-seo-sitemap.mjs",
    "check:seo:links": "node scripts/check-seo-links.mjs",
    "check:seo": "npm run check:seo:metadata && npm run check:seo:locale-diff && npm run check:seo:locale-links && npm run check:seo:templates && npm run check:seo:quality && npm run check:seo:html-lang && npm run check:seo:schema && npm run check:seo:schema:locale && npm run check:seo:og && npm run check:seo:robots && npm run check:seo:sitemap && npm run check:seo:links"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.542.0",
    "next": "15.5.0",
    "nodemailer": "^7.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "tailwind-merge": "^3.3.1",
    "three": "^0.171.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/eslint-plugin-next": "15.5.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "vitest": "^2.1.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "^5"
  }
}
