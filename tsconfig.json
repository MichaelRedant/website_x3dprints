{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Belangrijk: baseUrl + paths
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      // Elke key zonder wildcard -> exact 1 target
      "rehype-raw": [
        "./types/rehype-raw.d.ts"
      ],
      "rehype-sanitize": [
        "./types/rehype-sanitize.d.ts"
      ]
    },
    // NIET onder "paths" zetten. Als je 'typeRoots' wil gebruiken, doe je ’t hier:
    // "typeRoots": ["./types", "./node_modules/@types"],
    "types": [
      "node"
    ],
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
